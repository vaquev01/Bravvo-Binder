# ============================================
# BRAVVO OS - Frontend Environment Variables
# ============================================
# Copy this file to .env and fill in your values.
# VITE_ prefix is required for Vite to expose the variable to React.
# ============================================

# URL do Backend (deve incluir /api/v1)
VITE_API_URL=http://localhost:3001/api/v1

# Em produção, aponte para a URL do Railway:
# VITE_API_URL=https://bravvoapi-production.up.railway.app/api/v1
