{
  "name": "bravvo-os-monorepo",
  "private": true,
  "workspaces": [
    "apps/web",
    "apps/api",
    "apps/database"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test:e2e --workspaces --if-present",
    "test:e2e": "npm run test:e2e --workspaces --if-present",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up",
    "db:generate": "cd apps/database && npx prisma generate",
    "db:migrate": "cd apps/database && npx prisma migrate dev",
    "db:seed": "cd apps/database && npx tsx seed.ts",
    "db:push": "cd apps/database && npx prisma db push",
    "prepare": "husky"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.0"
  },
  "lint-staged": {
    "apps/web/**/*.{js,jsx,ts,tsx}": [
      "eslint --fix"
    ],
    "apps/api/**/*.{js,ts}": [
      "eslint --fix"
    ]
  }
}